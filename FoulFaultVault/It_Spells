<body>
<div class="container">
    <h1>🧠 v5.4 Semantic Primitive Parser</h1>
    <div class="sub">Enter a word or sentence – see how each letter (consonant/vowel) builds meaning</div>
    <input type="text" id="wordInput" placeholder="e.g., cat, dog, big, blackbird, I feel happy, tree R*" value="cat">
    <button id="parseButton">🔍 Parse & Show Meaning</button>
    <div id="outputArea" class="output">
        <!-- results will appear here -->
    </div>
</div>

<script>
    // --------------------------------------------------------------
    // v5.4 Semantic Parser – Letter‑level breakdown
    // --------------------------------------------------------------
    
    // Primitive meanings for consonants (user can extend this)
    const primitiveMeanings = {
        'C': 'container / shape_curved',
        'D': 'durable / object',
        'F': 'flow / fluid',
        'G': 'ground / base',
        'H': 'holding / enclosure',
        'K': 'cut / separation / stop',
        'L': 'layer / level',
        'M': 'motion / mass',
        'N': 'negation / not',
        'P': 'person / point',
        'R': 'repeat / again',
        'S': 'state / stillness',
        'T': 'tool / touch / straight',
        'U': 'you / container (as vowel)',
        'V': 'view / vision',
        'W': 'wave / water',
        'X': 'negation / hide',
        'Y': 'why / question',
        'Z': 'end / final',
        // Add more as needed – for demo we cover A-Z
        'A': '(vowel) merge/union',
        'E': '(vowel) sequence',
        'I': '(vowel) property/attribute',
        'O': '(vowel) alternative/xor',
        'B': 'body / root',
        'Q': 'question / query'
    };
    
    // Vowel operator semantics (binary between two consonants)
    const vowelSemantics = {
        'A': { name: 'UNION', desc: 'merge meanings (union of sets) – sibling relationship' },
        'E': { name: 'SEQUENCE', desc: 'temporal order – first consonant then second' },
        'I': { name: 'PROPERTY', desc: 'second consonant becomes attribute/property of first' },
        'O': { name: 'ALTERNATIVE', desc: 'mutual exclusive (xor)' },
        'U': { name: 'CONTAINER', desc: 'second consonant is inside first (nesting)' }
    };
    
    // Dictionary of atomic words (common short words that are not parsed as CVC)
    const atomicDictionary = {
        'cat': { type: 'animal', attributes: { fur: true, meow: true, size: 'small' }, visual: '🐱' },
        'dog': { type: 'animal', attributes: { fur: true, bark: true, size: 'medium' }, visual: '🐕' },
        'big': { type: 'adjective', attributes: { size: 'large' } },
        'small': { type: 'adjective', attributes: { size: 'small' } },
        'run': { type: 'verb', attributes: { action: 'move_fast' } },
        'happy': { type: 'emotion', attributes: { mood: 'joy', mouth: 'smile' } },
        'sad': { type: 'emotion', attributes: { mood: 'grief', mouth: 'frown' } },
        'tree': { type: 'plant', attributes: { trunk: true, leaves: true }, visual: '🌲' },
        'bird': { type: 'animal', attributes: { wings: true, fly: true }, visual: '🐦' },
        'black': { type: 'color', attributes: { color: '#000' } },
        'feel': { type: 'perception_verb', attributes: { applies_emotion: true } },
        'i': { type: 'pronoun', attributes: { self: true } }
    };
    
    // Helper: check if a word is atomic (in dictionary or short heuristic)
    function isAtomicWord(word) {
        let lower = word.toLowerCase();
        if (atomicDictionary[lower]) return true;
        // heuristic: 2-4 letters and contains a vowel? but we'll rely on dictionary for demo
        return false;
    }
    
    // Parse a single word according to v5.4: either atomic or treat as C V C pattern
    function parseWord(word) {
        let lower = word.toLowerCase();
        // Atomic word lookup
        if (atomicDictionary[lower]) {
            return {
                type: 'atomic',
                word: lower,
                meaning: atomicDictionary[lower],
                breakdown: `📖 Atomic word (dictionary entry): ${lower} → ${JSON.stringify(atomicDictionary[lower].attributes)}`
            };
        }
        
        // Check for compound (two atomic words concatenated, e.g., blackbird)
        // Try to split into two known atomic words
        for (let i = 2; i <= word.length-2; i++) {
            let first = word.slice(0, i).toLowerCase();
            let second = word.slice(i).toLowerCase();
            if (atomicDictionary[first] && atomicDictionary[second]) {
                return {
                    type: 'compound',
                    word: word,
                    left: first,
                    right: second,
                    operator: 'A', // implicit union
                    breakdown: `🔗 Compound: "${first}" + implicit A (union) + "${second}" → union of both meanings`,
                    meaning: { union: [atomicDictionary[first].attributes, atomicDictionary[second].attributes] }
                };
            }
        }
        
        // Otherwise, parse as consonant-vowel-consonant sequence (C V C ...)
        let letters = word.toUpperCase().split('');
        let result = {
            type: 'cvc_sequence',
            word: word,
            steps: [],
            finalMeaning: {}
        };
        
        let currentMeaning = null;
        let i = 0;
        while (i < letters.length) {
            let ch = letters[i];
            if (ch.match(/[BCDFGHJKLMNPQRSTVWXYZ]/)) {
                // consonant
                let consMeaning = primitiveMeanings[ch] || `primitive_${ch}`;
                result.steps.push({ type: 'consonant', letter: ch, meaning: consMeaning });
                if (currentMeaning === null) {
                    currentMeaning = { primitive: ch, meaningText: consMeaning };
                } else {
                    // Need a vowel before next consonant? Wait, pattern is C V C
                    // So after a consonant, we expect a vowel, then next consonant.
                    // But if no vowel found, treat as implicit? For simplicity, if next is consonant, we push as separate.
                    // Actually v5.4 vowel operators exist only between consonants inside a word.
                    // So we look ahead for a vowel.
                    if (i+1 < letters.length && letters[i+1].match(/[AEIOU]/)) {
                        let vowel = letters[i+1];
                        let vowelInfo = vowelSemantics[vowel] || { name: 'UNKNOWN', desc: 'unknown operator' };
                        if (i+2 < letters.length && letters[i+2].match(/[BCDFGHJKLMNPQRSTVWXYZ]/)) {
                            let nextCons = letters[i+2];
                            let nextMeaning = primitiveMeanings[nextCons] || `primitive_${nextCons}`;
                            result.steps.push({ type: 'vowel', letter: vowel, operator: vowelInfo.name, desc: vowelInfo.desc });
                            result.steps.push({ type: 'consonant', letter: nextCons, meaning: nextMeaning });
                            // Combine: currentMeaning (left) + vowel + nextMeaning (right)
                            let combined = `(${currentMeaning.meaningText}) ${vowelInfo.name} (${nextMeaning})`;
                            currentMeaning = { meaningText: combined, left: currentMeaning, operator: vowel, right: nextMeaning };
                            i += 2; // skip vowel and next consonant
                        } else {
                            // vowel but no following consonant -> invalid, treat vowel as separate? skip
                            result.steps.push({ type: 'vowel_orphan', letter: vowel, desc: 'no following consonant' });
                            i += 1;
                        }
                    } else {
                        // no vowel, just consonants adjacent: treat as implicit union? In v5.4, adjacent consonants are not allowed without vowel.
                        // So we push as separate primitive.
                        result.steps.push({ type: 'consonant', letter: ch, meaning: consMeaning, note: 'no vowel between' });
                        i += 1;
                    }
                }
                i += 1;
            } else if (ch.match(/[AEIOU]/)) {
                // vowel without preceding consonant? at start of word? treat as orphan.
                result.steps.push({ type: 'vowel_initial', letter: ch, desc: 'vowel at start – ignored or as operator on empty? In theory, needs left consonant' });
                i += 1;
            } else {
                i += 1;
            }
        }
        result.finalMeaning = currentMeaning ? currentMeaning.meaningText : '(no valid CVC pattern)';
        return result;
    }
    
    // Parse a sentence (split by spaces)
    function parseSentence(sentence) {
        let words = sentence.trim().split(/\s+/);
        let results = [];
        for (let w of words) {
            if (w === "") continue;
            // handle R* postfix: if word ends with R*, treat separately
            if (w.endsWith('R*')) {
                let base = w.slice(0, -2);
                let baseResult = parseWord(base);
                results.push({
                    raw: w,
                    type: 'repeat',
                    base: base,
                    repeatCount: 3,
                    details: `🔁 Repeat "${base}" 3 times (or until K/X) – ${baseResult.breakdown || baseResult.finalMeaning}`
                });
            } else {
                results.push(parseWord(w));
            }
        }
        return results;
    }
    
    // Render output
    function renderParseResults(parsedWords) {
        let html = '';
        for (let p of parsedWords) {
            html += `<div class="word-block">`;
            html += `<div class="word-title">📌 ${p.raw || p.word}</div>`;
            
            if (p.type === 'atomic') {
                html += `<div>${p.breakdown}</div>`;
                html += `<div class="meaning">🎯 Meaning: ${JSON.stringify(p.meaning.attributes)} ${p.meaning.visual || ''}</div>`;
            }
            else if (p.type === 'compound') {
                html += `<div>${p.breakdown}</div>`;
                html += `<div class="meaning">🔗 Combined: left "${p.left}" ∪ right "${p.right}" → union attributes</div>`;
            }
            else if (p.type === 'cvc_sequence') {
                html += `<div><strong>Letter‑by‑letter parse:</strong></div>`;
                for (let step of p.steps) {
                    let colorClass = (step.type === 'consonant') ? 'consonant' : 'vowel';
                    html += `<span class="letter-box ${colorClass}">${step.letter}</span>`;
                    if (step.meaning) html += `<span class="operator-desc"> → ${step.meaning}</span>`;
                    if (step.operator) html += `<span class="operator-desc"> [${step.operator}: ${step.desc}]</span>`;
                    html += `<br>`;
                }
                html += `<div class="meaning"><strong>📐 Combined semantic meaning:</strong> ${p.finalMeaning}</div>`;
            }
            else if (p.type === 'repeat') {
                html += `<div>${p.details}</div>`;
                html += `<div class="meaning">⚠️ Repetition yields multiple instances of the base meaning.</div>`;
            }
            else {
                html += `<div>${JSON.stringify(p)}</div>`;
            }
            html += `</div><hr>`;
        }
        return html;
    }
    
    // Main parse and display
    function parseAndDisplay() {
        let input = document.getElementById("wordInput").value;
        if (!input.trim()) {
            document.getElementById("outputArea").innerHTML = '<span style="color:#ff8888">Please enter a word or sentence.</span>';
            return;
        }
        let parsed = parseSentence(input);
        let html = renderParseResults(parsed);
        document.getElementById("outputArea").innerHTML = html;
    }
    
    document.getElementById("parseButton").addEventListener("click", parseAndDisplay);
    document.getElementById("wordInput").addEventListener("keypress", function(e) {
        if (e.key === 'Enter') parseAndDisplay();
    });
    
    // Initial parse
    parseAndDisplay();
</script>
</body>
